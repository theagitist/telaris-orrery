#!/usr/bin/env php
<?php
declare(strict_types=1);

/**
 * telaris-orrery: programmatic provisioner for the Telaris self-service instance plane.
 *
 * Phase 2 of the self-service-instances plan. Automates, idempotently and
 * reversibly, every step that was done by hand for the Phase-1 `fleet-test`
 * pod: validate the label, allocate a loopback port, create the
 * telaris_<label> database + owning role on the managed PostgreSQL cluster,
 * lay out the bind-mount tree, render the .kube Quadlet + unit, start the pod
 * under rootless Podman/systemd, seed schema + operator programmatically
 * (bin/provision-init inside the container), wire the host nginx route, and
 * record the instance in a local Orrery registry.
 *
 * Design (per the plan's Q5 trust boundary):
 *   - Every external process is run with an ARGUMENT ARRAY via proc_open, so no
 *     field is ever interpolated into a shell.
 *   - Every database existence check is PARAMETERIZED SQL; the only values that
 *     reach DDL are validated identifiers (label -> [a-z0-9_]) and a hex
 *     password (random_bytes), both charset-asserted before use.
 *   - The single OS-root operation is `systemctl reload nginx` (+ a read-only
 *     `nginx -t` validation), via one narrow sudoers line. Everything else is
 *     the Orrery user's own authority (rootless Podman, ~/.config systemd, a
 *     PG role with CREATEDB/CREATEROLE) -- no elevation.
 *
 * Orrery user: the invoking user (owns the rootless Podman setup, subuid/subgid,
 * linger). A dedicated non-human Orrery user is a later hardening.
 *
 * Subcommands:
 *   provision   <label> --operator-email=E [opts]   create + start + seed + route
 *   deprovision <label> [--yes]                      archive then destroy
 *   suspend     <label>                              stop the pod (data retained)
 *   resume      <label>                              start the pod again
 *   list                                             registry table
 *   inspect     <label>                              one instance, with live state
 *   help
 *
 * provision opts:
 *   --operator-first=, --operator-last=, --site-name=, --site-tagline=,
 *   --locale=en|es|pt|fr, --password=<plain> (omit => magic-link/no-password),
 *   --quota=<GB>|infinite (recorded only; enforcement is a later feature),
 *   --federate / --no-federate (default: federate; records intent + mints keypair),
 *   --force (re-run an existing label idempotently),
 *   --seed-script=<path> (dev: podman cp this provision-init into the container
 *                         instead of relying on the in-image copy).
 */

// ===========================================================================
// Configuration (env-overridable; defaults match this box)
// ===========================================================================
const APP_DESC = 'telaris-orrery provisioner';

function cfg(string $key, string $default): string {
    $v = getenv($key);
    return ($v !== false && $v !== '') ? $v : $default;
}

define('INSTANCES_ROOT', cfg('TELARIS_INSTANCES_ROOT', '/mnt/polivoxiadata/telaris-instances'));
define('BACKUPS_ROOT',   cfg('TELARIS_BACKUPS_ROOT',   '/mnt/polivoxiadata/telaris-backups'));
define('KEYS_DIR',       cfg('TELARIS_KEYS_DIR',       getenv('HOME') . '/apps/keys'));
define('ADMIN_CREDS',    cfg('TELARIS_PG_ADMIN_CREDS', getenv('HOME') . '/apps/keys/managed-polivoxia-pg1-database'));
define('DB_SSL_CA',      cfg('TELARIS_DB_SSL_CA',      '/etc/ssl/polivoxia-pg1-ca.crt'));
define('IMAGE_APP',      cfg('TELARIS_IMAGE_APP',      'localhost/telaris-app:dev'));
define('IMAGE_WEB',      cfg('TELARIS_IMAGE_WEB',      'localhost/telaris-web:dev'));
define('WILDCARD_BASE',  cfg('TELARIS_WILDCARD_BASE',  'telaris.ca'));
define('QUADLET_DIR',    cfg('TELARIS_QUADLET_DIR',    getenv('HOME') . '/.config/containers/systemd'));
define('NGINX_ORRERY_DIR',cfg('TELARIS_NGINX_ORRERY_DIR','/etc/nginx/telaris-orrery'));
// Shared origin TLS for the instance tier (provider-neutral). When BOTH a cert
// and key path are set AND the cert file exists, render_vhost() adds a 443
// listener using them; otherwise the vhost is HTTP-only (the cert-less default).
// On this box these point at a Cloudflare Origin CA cert covering *.telaris.ca,
// but the Orrery does not care where the cert came from (LE wildcard, per-host,
// or an Origin CA cert all work). The matching public CDN/edge TLS, if any, is
// the operator's concern, not the Orrery's.
define('INSTANCE_TLS_CERT', cfg('TELARIS_INSTANCE_TLS_CERT', '/etc/ssl/telaris-instance-origin.crt'));
define('INSTANCE_TLS_KEY',  cfg('TELARIS_INSTANCE_TLS_KEY',  '/etc/ssl/telaris-instance-origin.key'));
// Pluriverse checkout, for the one www-data step that encrypts + inserts a
// federation instances row on CLI provision (the PII master key is www-data
// only). Empty/unreachable -> CLI provision just skips auto-trust.
define('PLURIVERSE_APP_DIR', cfg('TELARIS_PLURIVERSE_APP_DIR', '/var/www/www.telaris.ca'));
define('REGISTRY_FILE',  cfg('TELARIS_ORRERY_REGISTRY', dirname(__DIR__) . '/registry.json'));
define('MAIL_FROM_NAME', cfg('TELARIS_MAIL_FROM_NAME', 'Telaris'));
// SMTP relay injected into every provisioned instance so it can send mail out of
// the box (config-driven; ZeptoMail by default). The token is read at provision
// time from MAIL_PASS_FILE (a ZeptoMail "Password 1: <token>" descriptor or a
// plain token file); if it is unreadable the instance is born mail-less.
define('MAIL_FROM_ADDRESS', cfg('TELARIS_MAIL_FROM_ADDRESS', 'no-reply@telaris.ca'));
define('MAIL_SMTP_HOST',    cfg('TELARIS_MAIL_HOST',   'smtp.zeptomail.com'));
define('MAIL_SMTP_PORT',    cfg('TELARIS_MAIL_PORT',   '587'));
define('MAIL_SMTP_USER',    cfg('TELARIS_MAIL_USER',   'emailapikey'));
define('MAIL_SMTP_SECURE',  cfg('TELARIS_MAIL_SECURE', 'tls'));
define('MAIL_PASS_FILE',    cfg('TELARIS_MAIL_PASS_FILE', getenv('HOME') . '/apps/keys/zeptomail'));
define('PORT_MIN', (int)cfg('TELARIS_PORT_MIN', '18080'));
define('PORT_MAX', (int)cfg('TELARIS_PORT_MAX', '18999'));
define('DEFAULT_QUOTA_GB', cfg('TELARIS_DEFAULT_QUOTA_GB', '5'));

define('PG_DUMP', cfg('TELARIS_PG_DUMP', '/usr/lib/postgresql/18/bin/pg_dump'));
define('PODMAN',  cfg('TELARIS_PODMAN', '/usr/bin/podman'));
define('SYSTEMCTL', '/usr/bin/systemctl');
define('SUDO', '/usr/bin/sudo');
define('NGINX', '/usr/sbin/nginx');
define('CURL', '/usr/bin/curl');
define('TAR', '/usr/bin/tar');

// --- Pluriverse bridge (ALL access to Pluriverse-owned tables goes through it) ---
// The Orrery holds NO database credentials to the Pluriverse and NO PII master
// key. Every read/write of the federation `instances` registry and the
// `provisioning_jobs` queue is performed by invoking this committed dispatcher
// as www-data (see pluriverse_call()). www-data owns that schema and the PII
// key; the Orrery only names whitelisted functions. This is the entire trust
// surface the Orrery has into the Pluriverse.
define('BRIDGE_SCRIPT', PLURIVERSE_APP_DIR . '/bin/pluriverse-bridge.php');
// Operator-identity handoff key, shared between the Pluriverse web app (seals at
// approve time, runs as www-data) and this worker (unseals, runs as the Orrery
// user). A narrow capability: it decrypts only the per-job operator handoff
// blob, never the Pluriverse PII master key (which stays www-data-only). The
// job payload therefore carries no plaintext PII at rest.
define('HANDOFF_KEY_FILE', cfg('TELARIS_ORRERY_HANDOFF_KEY', '/etc/telaris-orrery/handoff.key'));
define('WORKER_MAX_JOBS',     (int)cfg('TELARIS_ORRERY_WORKER_MAX_JOBS', '10'));
define('WORKER_MAX_ATTEMPTS', (int)cfg('TELARIS_ORRERY_WORKER_MAX_ATTEMPTS', '5'));

// Reserved labels that must never be provisioned (collide with real hosts /
// special names). Extend as the Orrery grows.
const RESERVED_LABELS = [
    'www', 'mail', 'admin', 'api', 'ns', 'ns1', 'ns2', 'mx', 'ftp', 'smtp',
    'imap', 'pop', 'webmail', 'cpanel', 'whm', 'localhost', 'pluriverse',
    'orrery', 'observatory', 'telaris', 'starmaps', 'grsj306', 'qwsp',
    'fleet', 'test', 'staging', 'prod', 'production', 'root', 'postgres',
];

// ===========================================================================
// Small utilities
// ===========================================================================

/** A controlled, expected failure. The top-level dispatch prints it + exits 1;
 *  the `work` loop catches it per-job so one bad job never kills the worker. */
class OrreryError extends RuntimeException {}

function out(string $s): void { fwrite(STDOUT, $s . "\n"); }
function info(string $s): void { fwrite(STDOUT, "  " . $s . "\n"); }
function step(string $s): void { fwrite(STDOUT, "[*] " . $s . "\n"); }
function warn(string $s): void { fwrite(STDERR, "[!] " . $s . "\n"); }
function fail(string $s): never { throw new OrreryError($s); }

/** Session env so rootless `podman` / `systemctl --user` reach the user manager. */
function user_env(): array {
    $uid = posix_getuid();
    $name = posix_getpwuid($uid)['name'] ?? '';
    return [
        'PATH' => getenv('PATH') ?: '/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin',
        'HOME' => getenv('HOME') ?: ('/home/' . $name),
        'XDG_RUNTIME_DIR' => '/run/user/' . $uid,
        'DBUS_SESSION_BUS_ADDRESS' => 'unix:path=/run/user/' . $uid . '/bus',
    ];
}

/**
 * Run a process with an argument array (NO shell). Returns code/out/err.
 * @param array<int,string> $cmd
 * @param array<string,string> $extraEnv merged over user_env()
 */
function run(array $cmd, array $extraEnv = [], ?string $stdin = null): array {
    $env = array_merge(user_env(), $extraEnv);
    $desc = [0 => ['pipe', 'r'], 1 => ['pipe', 'w'], 2 => ['pipe', 'w']];
    $proc = proc_open($cmd, $desc, $pipes, null, $env);
    if (!is_resource($proc)) {
        throw new RuntimeException('proc_open failed: ' . implode(' ', $cmd));
    }
    if ($stdin !== null) { fwrite($pipes[0], $stdin); }
    fclose($pipes[0]);
    $o = stream_get_contents($pipes[1]); fclose($pipes[1]);
    $e = stream_get_contents($pipes[2]); fclose($pipes[2]);
    $code = proc_close($proc);
    return ['code' => $code, 'out' => (string)$o, 'err' => (string)$e];
}

function run_ok(array $cmd, string $what, array $extraEnv = [], ?string $stdin = null): string {
    $r = run($cmd, $extraEnv, $stdin);
    if ($r['code'] !== 0) {
        throw new RuntimeException("$what failed (exit {$r['code']}): " . trim($r['err'] ?: $r['out']));
    }
    return $r['out'];
}

// ===========================================================================
// Validation + identifier safety
// ===========================================================================

function validate_label(string $label): string {
    $label = strtolower(trim($label));
    if (!preg_match('/^[a-z][a-z0-9-]{1,30}$/', $label)) {
        fail("Invalid label '$label': must be lowercase, start with a letter, [a-z0-9-], 2-31 chars.");
    }
    if (str_contains($label, '--') || str_ends_with($label, '-')) {
        fail("Invalid label '$label': no trailing or doubled hyphens.");
    }
    if (in_array($label, RESERVED_LABELS, true)) {
        fail("Label '$label' is reserved.");
    }
    return $label;
}

/** DB + role name from a validated label (dashes -> underscores; telaris_ prefix). */
function db_name_for(string $label): string {
    $name = 'telaris_' . str_replace('-', '_', $label);
    if (!preg_match('/^[a-z_][a-z0-9_]*$/', $name)) {
        fail("Derived DB name '$name' is not a safe identifier."); // defence in depth
    }
    return $name;
}

/** Quote a PostgreSQL identifier (already charset-validated; double-quote + escape). */
function pg_ident(string $id): string {
    if (!preg_match('/^[a-z_][a-z0-9_]*$/', $id)) {
        throw new RuntimeException("Refusing to quote unsafe identifier: $id");
    }
    return '"' . str_replace('"', '""', $id) . '"';
}

/** Quote a PG string literal. */
function pg_lit(string $s): string {
    return "'" . str_replace("'", "''", $s) . "'";
}

function assert_hex(string $s): void {
    if (!preg_match('/^[0-9a-f]+$/', $s)) {
        throw new RuntimeException('Expected a hex token; refusing.');
    }
}

// ===========================================================================
// Managed PostgreSQL admin
// ===========================================================================

/** @return array<string,string> */
function admin_creds(): array {
    if (!is_readable(ADMIN_CREDS)) {
        fail('Managed PG admin creds not readable: ' . ADMIN_CREDS);
    }
    $creds = [];
    foreach (file(ADMIN_CREDS, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (preg_match('/^\s*([a-zA-Z_]+)\s*=\s*(.*)$/', $line, $m)) {
            $creds[strtolower($m[1])] = trim($m[2]);
        }
    }
    foreach (['host', 'port', 'username', 'password', 'database'] as $k) {
        if (!isset($creds[$k])) {
            fail("Managed PG admin creds missing '$k'.");
        }
    }
    $creds['sslmode'] = $creds['sslmode'] ?? 'require';
    return $creds;
}

function admin_pdo(?string $dbname = null): PDO {
    $c = admin_creds();
    $db = $dbname ?? $c['database'];
    $dsn = "pgsql:host={$c['host']};port={$c['port']};dbname={$db};sslmode={$c['sslmode']}";
    if (is_readable(DB_SSL_CA)) {
        $dsn .= ';sslrootcert=' . DB_SSL_CA;
    }
    return new PDO($dsn, $c['username'], $c['password'], [
        PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_TIMEOUT => 15,
    ]);
}

function pg_role_exists(PDO $pdo, string $role): bool {
    $s = $pdo->prepare('SELECT 1 FROM pg_roles WHERE rolname = :r');
    $s->execute([':r' => $role]);
    return (bool)$s->fetchColumn();
}

function pg_db_exists(PDO $pdo, string $db): bool {
    $s = $pdo->prepare('SELECT 1 FROM pg_database WHERE datname = :d');
    $s->execute([':d' => $db]);
    return (bool)$s->fetchColumn();
}

function db_provision(string $dbName, string $dbUser, string $dbPass): void {
    assert_hex($dbPass);
    $pdo = admin_pdo();
    if (!pg_role_exists($pdo, $dbUser)) {
        step("creating role $dbUser");
        $pdo->exec(sprintf('CREATE ROLE %s LOGIN PASSWORD %s', pg_ident($dbUser), pg_lit($dbPass)));
    } else {
        info("role $dbUser already exists");
    }
    if (!pg_db_exists($pdo, $dbName)) {
        step("creating database $dbName");
        $pdo->exec(sprintf('CREATE DATABASE %s OWNER %s', pg_ident($dbName), pg_ident($dbUser)));
    } else {
        info("database $dbName already exists");
    }
    $idb = admin_pdo($dbName);
    $idb->exec('CREATE EXTENSION IF NOT EXISTS unaccent');
    info('unaccent extension ensured');
}

function db_dump(string $dbName, string $destFile): void {
    $c = admin_creds();
    $env = [
        'PGPASSWORD' => $c['password'],
        'PGSSLMODE' => $c['sslmode'],
        'PGSSLROOTCERT' => DB_SSL_CA,
    ];
    run_ok(
        [PG_DUMP, '-h', $c['host'], '-p', $c['port'], '-U', $c['username'], '-Fc', '-f', $destFile, $dbName],
        "pg_dump $dbName",
        $env
    );
}

function db_drop(string $dbName, string $dbUser): void {
    $pdo = admin_pdo();
    if (pg_db_exists($pdo, $dbName)) {
        step("dropping database $dbName (FORCE)");
        // PG13+ FORCE terminates remaining backends automatically.
        $pdo->exec(sprintf('DROP DATABASE IF EXISTS %s WITH (FORCE)', pg_ident($dbName)));
    }
    if (pg_role_exists($pdo, $dbUser)) {
        step("dropping role $dbUser");
        $pdo->exec(sprintf('DROP ROLE IF EXISTS %s', pg_ident($dbUser)));
    }
}

// ===========================================================================
// Registry (local JSON; the Pluriverse `instances` table supersedes it later)
// ===========================================================================

/** @return array<string,array<string,mixed>> */
function registry_load(): array {
    if (!is_file(REGISTRY_FILE)) {
        return [];
    }
    $data = json_decode((string)file_get_contents(REGISTRY_FILE), true);
    return is_array($data) ? $data : [];
}

function registry_save(array $reg): void {
    ksort($reg);
    $tmp = REGISTRY_FILE . '.tmp';
    file_put_contents($tmp, json_encode($reg, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n");
    chmod($tmp, 0600);
    rename($tmp, REGISTRY_FILE);
}

function allocate_port(array $reg): int {
    $used = [];
    foreach ($reg as $r) {
        if (isset($r['port'])) { $used[(int)$r['port']] = true; }
    }
    for ($p = PORT_MIN; $p <= PORT_MAX; $p++) {
        if (isset($used[$p])) { continue; }
        $sock = @fsockopen('127.0.0.1', $p, $errno, $errstr, 0.2);
        if ($sock !== false) { fclose($sock); continue; } // something is listening
        return $p;
    }
    fail('No free port in range ' . PORT_MIN . '-' . PORT_MAX);
}

// ===========================================================================
// Filesystem layout
// ===========================================================================

function instance_dir(string $label): string { return INSTANCES_ROOT . '/' . $label; }
function backups_dir(string $label): string { return BACKUPS_ROOT . '/' . $label; }

function make_tree(string $label): void {
    $base = instance_dir($label);
    // Container-written data dirs (the app entrypoint chowns these to www-data
    // = host uid 100032 in the rootless userns).
    foreach (['uploads', 'snapshots', 'logs', 'var', 'secrets', 'hg-content'] as $d) {
        if (!is_dir("$base/$d")) { mkdir("$base/$d", 0775, true); }
    }
    // Host-Orrery-user-owned config dir: holds the .kube YAML (which the host
    // systemd reads on restart, so it must NOT be inside a container-chowned dir).
    if (!is_dir("$base/conf")) { mkdir("$base/conf", 0700, true); }
    foreach ([backups_dir($label) . '/db', backups_dir($label) . '/files'] as $d) {
        if (!is_dir($d)) { mkdir($d, 0775, true); }
    }
}

// ===========================================================================
// .kube YAML + Quadlet unit
// ===========================================================================

/**
 * @param array<string,string> $envPairs
 */
function render_kube_yaml(string $label, int $port, array $envPairs): string {
    $base = instance_dir($label);
    $pod = 'telaris-' . $label;

    $envBlock = function (string $indent) use ($envPairs): string {
        $lines = [];
        foreach ($envPairs as $k => $v) {
            $lines[] = $indent . "- name: $k";
            $lines[] = $indent . "  value: " . pg_lit_yaml($v);
        }
        return implode("\n", $lines);
    };

    // The data volume mounts shared by app + cron.
    $mounts = [
        ['uploads',   '/var/www/html/uploads'],
        ['snapshots', '/var/www/html/telaris-snapshots'],
        ['logs',      '/var/www/html/logs'],
        ['var',       '/var/www/html/var'],
        ['secrets',   '/var/www/html/secrets'],
        ['hgcontent', '/var/www/html/hg/content'],
    ];
    $mountBlock = function (string $indent) use ($mounts): string {
        $lines = [];
        foreach ($mounts as [$name, $path]) {
            $lines[] = $indent . "- name: $name";
            $lines[] = $indent . "  mountPath: $path";
        }
        $lines[] = $indent . "- name: ca";
        $lines[] = $indent . "  mountPath: " . DB_SSL_CA;
        $lines[] = $indent . "  readOnly: true";
        return implode("\n", $lines);
    };

    $hostPaths = [
        ['uploads',   "$base/uploads"],
        ['snapshots', "$base/snapshots"],
        ['logs',      "$base/logs"],
        ['var',       "$base/var"],
        ['secrets',   "$base/secrets"],
        ['hgcontent', "$base/hg-content"],
    ];
    $volLines = [];
    foreach ($hostPaths as [$name, $path]) {
        $volLines[] = "    - name: $name";
        $volLines[] = "      hostPath:";
        $volLines[] = "        path: $path";
        $volLines[] = "        type: Directory";
    }
    $volLines[] = "    - name: ca";
    $volLines[] = "      hostPath:";
    $volLines[] = "        path: " . DB_SSL_CA;
    $volLines[] = "        type: File";
    $volumes = implode("\n", $volLines);

    $env6 = $envBlock('        ');
    $mounts8 = $mountBlock('        ');
    $imgApp = IMAGE_APP;
    $imgWeb = IMAGE_WEB;

    return <<<YAML
apiVersion: v1
kind: Pod
metadata:
  name: $pod
  labels:
    app: $pod
spec:
  hostAliases:
    - ip: 127.0.0.1
      hostnames:
        - app
  containers:
    - name: app
      image: $imgApp
      args:
        - php-fpm
      env:
$env6
      ports:
        - containerPort: 80
          hostIP: 127.0.0.1
          hostPort: $port
      volumeMounts:
$mounts8
    - name: web
      image: $imgWeb
      args:
        - nginx
        - "-g"
        - "daemon off;"
    - name: cron
      image: $imgApp
      command:
        - /usr/local/bin/entrypoint-cron.sh
      env:
$env6
      volumeMounts:
$mounts8
  volumes:
$volumes

YAML;
}

/** Quote a YAML scalar value safely (single-quoted, doubled internal quotes). */
function pg_lit_yaml(string $v): string {
    return "'" . str_replace("'", "''", $v) . "'";
}

function quadlet_path(string $label): string {
    return QUADLET_DIR . '/telaris-' . $label . '.kube';
}

function render_quadlet(string $label, string $yamlPath): string {
    return <<<UNIT
[Unit]
Description=Telaris instance: $label
After=network-online.target
Wants=network-online.target

[Kube]
Yaml=$yamlPath

[Install]
WantedBy=default.target

UNIT;
}

// ===========================================================================
// Pod lifecycle helpers
// ===========================================================================

function service_name(string $label): string { return 'telaris-' . $label . '.service'; }
function app_container(string $label): string { return 'telaris-' . $label . '-app'; }

function systemd_user(array $args, string $what): string {
    return run_ok(array_merge([SYSTEMCTL, '--user'], $args), $what);
}

function wait_http(int $port, int $timeoutSec = 120): string {
    $deadline = time() + $timeoutSec;
    $last = '000';
    while (time() < $deadline) {
        $r = run([CURL, '-s', '-o', '/dev/null', '-w', '%{http_code}', '--max-time', '5',
                  "http://127.0.0.1:$port/"]);
        $last = trim($r['out']);
        if ($last !== '000' && $last !== '') {
            return $last;
        }
        usleep(2_000_000);
    }
    return $last;
}

function curl_status(int $port): string {
    $r = run([CURL, '-s', '-o', '/dev/null', '-w', '%{http_code}', '--max-time', '8',
              "http://127.0.0.1:$port/"]);
    return trim($r['out']);
}

// ===========================================================================
// nginx route
// ===========================================================================

function nginx_vhost_path(string $label): string { return NGINX_ORRERY_DIR . '/' . $label . '.conf'; }

function render_vhost(string $label, string $hostname, int $port): string {
    // The reverse-proxy location block, shared by the :80 and :443 servers.
    $proxy = <<<NGINX
    client_max_body_size 55m;

    location / {
        proxy_pass http://127.0.0.1:$port;
        proxy_http_version 1.1;
        proxy_set_header Host              \$host;
        proxy_set_header X-Real-IP         \$remote_addr;
        proxy_set_header X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }
NGINX;

    $out = "# Telaris instance: $label  (generated by telaris-orrery; do not edit)\n";
    $out .= "server {\n    listen 80;\n    listen [::]:80;\n    server_name $hostname;\n$proxy\n}\n";

    // Add a 443 server only when a shared origin cert is configured + present.
    // The CF->origin (or any CDN->origin) hop is encrypted; the public-facing
    // cert is the CDN's (or this same cert, CDN-less). Cert-less installs stay
    // HTTP-only, exactly as before.
    if (INSTANCE_TLS_CERT !== '' && INSTANCE_TLS_KEY !== '' && is_file(INSTANCE_TLS_CERT)) {
        $cert = INSTANCE_TLS_CERT;
        $key  = INSTANCE_TLS_KEY;
        $out .= "\nserver {\n    listen 443 ssl;\n    listen [::]:443 ssl;\n    server_name $hostname;\n";
        $out .= "    ssl_certificate     $cert;\n    ssl_certificate_key $key;\n$proxy\n}\n";
    }

    return $out . "\n";
}

function nginx_reload(): void {
    // read-only validation first (harmless, no privilege-escalation surface)
    $t = run([SUDO, '-n', NGINX, '-t']);
    if ($t['code'] !== 0) {
        throw new RuntimeException('nginx -t failed; not reloading: ' . trim($t['err'] ?: $t['out']));
    }
    run_ok([SUDO, '-n', SYSTEMCTL, 'reload', 'nginx'], 'systemctl reload nginx');
}

// ===========================================================================
// provision
// ===========================================================================

/**
 * 3f auto-trust for CLI provisions: create the PENDING Pluriverse `instances`
 * row through the www-data bridge (only www-data holds the PII master key that
 * encrypts the operator email), reusing the SAME db_create_pending_federation_
 * instance() the request/approval flow uses. Returns the new instance id, or 0
 * if it could not be created (already present / Pluriverse not co-located /
 * error). The caller then publishes it with worker_publish_instance().
 * Best-effort: a 0 just means "no auto-trust", the instance still serves.
 */
function orrery_register_pending_instance(string $label, string $email, string $locale, string $framing): int {
    try {
        return (int)pluriverse_call('register_pending', [$label, $email, $locale, $framing]);
    } catch (Throwable $e) {
        warn('federation register (bridge) failed: ' . $e->getMessage());
        return 0;
    }
}

/**
 * SMTP env for a provisioned instance, read from the mail keyfile at provision
 * time. Returns the MAIL_* pairs render-config.sh maps into the in-container
 * config.php, or [] if the token cannot be read (instance is then born
 * mail-less, which is a warning, not a failure). Accepts either a ZeptoMail
 * descriptor (a "Password 1: <token>" line) or a plain one-line token file.
 *
 * @return array<string,string>
 */
function mail_env(): array {
    if (!is_readable(MAIL_PASS_FILE)) {
        warn('mail: ' . MAIL_PASS_FILE . ' not readable; instance provisioned without SMTP');
        return [];
    }
    $raw = (string)file_get_contents(MAIL_PASS_FILE);
    $token = '';
    foreach (preg_split('/\r?\n/', $raw) as $line) {
        if (stripos($line, 'Password 1:') === 0) {
            $token = trim(substr($line, strlen('Password 1:')));
            break;
        }
    }
    if ($token === '') { $token = trim($raw); } // plain token file
    if ($token === '') {
        warn('mail: no token parsed from ' . MAIL_PASS_FILE . '; instance provisioned without SMTP');
        return [];
    }
    return [
        'MAIL_SMTP_HOST'    => MAIL_SMTP_HOST,
        'MAIL_SMTP_PORT'    => MAIL_SMTP_PORT,
        'MAIL_SMTP_USER'    => MAIL_SMTP_USER,
        'MAIL_SMTP_PASS'    => $token,
        'MAIL_SMTP_SECURE'  => MAIL_SMTP_SECURE,
        'MAIL_FROM_ADDRESS' => MAIL_FROM_ADDRESS,
    ];
}

/** @param array<string,string|bool> $opts */
function cmd_provision(string $label, array $opts): void {
    $label = validate_label($label);
    $email = (string)($opts['operator-email'] ?? '');
    if ($email === '' || !filter_var($email, FILTER_VALIDATE_EMAIL)) {
        fail('--operator-email=<valid email> is required for provision.');
    }
    $force = !empty($opts['force']);
    $federate = !array_key_exists('no-federate', $opts);

    $reg = registry_load();
    if (isset($reg[$label]) && !$force) {
        fail("Instance '$label' already in the registry. Use --force to re-run idempotently.");
    }

    $dbName = db_name_for($label);
    $dbUser = $dbName;
    $hostname = $label . '.' . WILDCARD_BASE;
    $port = isset($reg[$label]['port']) ? (int)$reg[$label]['port'] : allocate_port($reg);

    out("Provisioning instance '$label'");
    info("hostname: $hostname");
    info("database: $dbName  role: $dbUser");
    info("port:     127.0.0.1:$port");

    // --- DB role password: reuse keyfile if present, else generate ---
    $keyfile = KEYS_DIR . '/telaris-' . $label . '-postgres';
    if (is_file($keyfile)) {
        $dbPass = trim((string)file_get_contents($keyfile));
        info("reusing existing DB password keyfile");
    } else {
        $dbPass = bin2hex(random_bytes(24));
        file_put_contents($keyfile, $dbPass . "\n");
        chmod($keyfile, 0600);
        info("wrote DB password keyfile: $keyfile (600)");
    }
    assert_hex($dbPass);

    // --- managed PG: role + database + unaccent ---
    db_provision($dbName, $dbUser, $dbPass);

    // --- filesystem tree ---
    step('creating instance tree under ' . instance_dir($label));
    make_tree($label);

    // --- render .kube YAML (host-owned conf/) + Quadlet unit ---
    $quotaStr = (string)($opts['quota'] ?? DEFAULT_QUOTA_GB);
    $envPairs = [
        'DB_HOST' => admin_creds()['host'],
        'DB_PORT' => admin_creds()['port'],
        'DB_NAME' => $dbName,
        'DB_USER' => $dbUser,
        'DB_PASS' => $dbPass,
        'DB_SSL_CA' => DB_SSL_CA,
        'TELARIS_HOSTNAME' => $hostname,
        'MAIL_FROM_NAME' => MAIL_FROM_NAME,
        // Disk quota the instance app self-enforces at upload time (0 = unlimited).
        'TELARIS_QUOTA_BYTES' => (string)quota_bytes($quotaStr),
    ];
    // Inject the SMTP relay (ZeptoMail by default) so the instance can send mail
    // immediately; no-op (warns) if the token keyfile is unreadable.
    $envPairs = array_merge($envPairs, mail_env());
    $yamlPath = instance_dir($label) . '/conf/' . $label . '.kube.yaml';
    file_put_contents($yamlPath, render_kube_yaml($label, $port, $envPairs));
    chmod($yamlPath, 0600);
    info("wrote $yamlPath (600)");

    if (!is_dir(QUADLET_DIR)) { mkdir(QUADLET_DIR, 0755, true); }
    file_put_contents(quadlet_path($label), render_quadlet($label, $yamlPath));
    info('wrote Quadlet unit ' . quadlet_path($label));

    // --- systemd: reload + start ---
    step('systemctl --user daemon-reload');
    systemd_user(['daemon-reload'], 'daemon-reload');
    step('starting ' . service_name($label));
    systemd_user(['start', service_name($label)], 'start ' . service_name($label));

    // --- wait for the web server to answer ---
    step("waiting for the pod to answer on 127.0.0.1:$port ...");
    $code = wait_http($port);
    if ($code === '000' || $code === '') {
        fail("Pod did not answer on port $port. Check: systemctl --user status " . service_name($label));
    }
    info("pod answers (HTTP $code)");

    // --- dev convenience: copy a provision-init into the container ---
    if (!empty($opts['seed-script'])) {
        $src = (string)$opts['seed-script'];
        if (!is_file($src)) { fail("--seed-script not found: $src"); }
        step('copying provision-init into the container');
        run_ok([PODMAN, 'cp', $src, app_container($label) . ':/var/www/html/bin/provision-init'], 'podman cp provision-init');
        run_ok([PODMAN, 'exec', app_container($label), 'chmod', '0755', '/var/www/html/bin/provision-init'], 'chmod provision-init');
    }

    // --- seed schema + operator programmatically (inside the container) ---
    step('seeding schema + operator (bin/provision-init)');
    $initArgs = [
        PODMAN, 'exec', app_container($label),
        'php', '/var/www/html/bin/provision-init',
        '--operator-email=' . $email,
    ];
    if (!empty($opts['operator-first'])) { $initArgs[] = '--operator-first=' . $opts['operator-first']; }
    if (!empty($opts['operator-last']))  { $initArgs[] = '--operator-last=' . $opts['operator-last']; }
    if (!empty($opts['site-name']))      { $initArgs[] = '--site-name=' . $opts['site-name']; }
    if (!empty($opts['site-tagline']))   { $initArgs[] = '--site-tagline=' . $opts['site-tagline']; }
    if (!empty($opts['locale']))         { $initArgs[] = '--locale=' . $opts['locale']; }
    if (!empty($opts['password']))       { $initArgs[] = '--password=' . $opts['password']; }
    $r = run($initArgs);
    fwrite(STDOUT, $r['out']);
    if ($r['err'] !== '') { fwrite(STDERR, $r['err']); }
    if ($r['code'] !== 0) {
        fail('provision-init failed; instance left running for inspection.');
    }
    if (preg_match('/PROVISION_INIT_RESULT:(\{.*\})/', $r['out'], $m)) {
        $res = json_decode($m[1], true);
        info('seed: operator=' . ($res['operator'] ?? '?')
            . ', tables_created=' . count($res['tables_created'] ?? [])
            . ', db_ensure_ran=' . ($res['db_ensure_ran'] ?? '?'));
    }

    // --- verify home now serves 200 ---
    $code = curl_status($port);
    info("home now returns HTTP $code" . ($code === '200' ? ' (seeded OK)' : ' (expected 200)'));

    // --- host nginx route ---
    step("writing nginx vhost for $hostname");
    file_put_contents(nginx_vhost_path($label), render_vhost($label, $hostname, $port));
    nginx_reload();
    info('nginx reloaded');

    // --- federation identity (minted by the entrypoint; report it) ---
    $keyid = '(pending)';
    $r = run([PODMAN, 'exec', app_container($label), 'php', '-r',
        'require_once "/var/www/html/config.php"; '
        . 'require_once "/var/www/html/inc/federation/identity.php"; '
        . 'echo federation_keyid(federation_local_hostname());']);
    if (trim($r['out']) !== '' && !str_contains($r['out'], 'error')) { $keyid = trim($r['out']); }

    // --- registry record ---
    $reg = registry_load();
    $reg[$label] = [
        'label' => $label,
        'hostname' => $hostname,
        'port' => $port,
        'db_name' => $dbName,
        'db_user' => $dbUser,
        'status' => 'running',
        'federate' => $federate,
        'keyid' => $keyid,
        'quota' => $quotaStr,
        'operator_email' => $email,
        'created' => gmdate('c'),
    ];
    registry_save($reg);

    out('');
    out("Provisioned '$label'.");
    info("URL (local): curl -H 'Host: $hostname' http://127.0.0.1:$port/   (or via the host vhost once DNS resolves)");
    info("federation keyid: $keyid");
    if ($federate) {
        // 3f auto-trust: www-data creates the encrypted pending instances row,
        // then we backfill the minted key + publish it (same two helpers the
        // request/approval worker uses). Best-effort; never aborts a provision.
        $iid = orrery_register_pending_instance($label, $email, (string)($opts['locale'] ?? 'en'), (string)($opts['site-tagline'] ?? ''));
        if ($iid > 0) {
            try {
                $pub = worker_publish_instance($iid, $label);
                info("federation: published to the Pluriverse (instances#$iid" . ($pub ? ", $pub" : '') . ').');
            } catch (Throwable $e) {
                warn('federation publish failed (non-fatal): ' . $e->getMessage());
            }
        } else {
            info('federation: opted IN, keypair minted; Pluriverse row not recorded (already present, or Pluriverse not reachable from here).');
        }
    }
    info('quota: ' . $quotaStr . ' GB (' . quota_bytes($quotaStr) . ' bytes; app blocks new uploads over quota, Orrery records usage each worker tick)');
    if (empty($opts['password'])) {
        info('operator has NO password (magic-link login); configure SMTP + trigger a login link, or re-provision with --password=.');
    }
}

// ===========================================================================
// deprovision
// ===========================================================================

function cmd_deprovision(string $label, array $opts): void {
    $label = validate_label($label);
    $reg = registry_load();
    $rec = $reg[$label] ?? null;
    $dbName = $rec['db_name'] ?? db_name_for($label);
    $dbUser = $rec['db_user'] ?? $dbName;

    if (empty($opts['yes'])) {
        out("About to DEPROVISION '$label':");
        info("- archive DB dump + files to " . backups_dir($label));
        info("- stop + remove the pod and its Quadlet unit");
        info("- DROP database $dbName + role $dbUser on managed PG");
        info("- remove the instance tree " . instance_dir($label) . " and the nginx route");
        info("- retract its Pluriverse federation registration (if federated)");
        fwrite(STDOUT, "Type the label to confirm: ");
        $ans = trim((string)fgets(STDIN));
        if ($ans !== $label) { fail('Confirmation did not match; aborted.'); }
    }

    $stamp = gmdate('Ymd-His');

    // --- archive FIRST (data loss is not acceptable) ---
    if (pg_db_exists(admin_pdo(), $dbName)) {
        step("archiving DB dump");
        if (!is_dir(backups_dir($label) . '/db')) { mkdir(backups_dir($label) . '/db', 0775, true); }
        db_dump($dbName, backups_dir($label) . "/db/$dbName-$stamp.dump");
        info('DB archived');
    }
    if (is_dir(instance_dir($label))) {
        step('archiving files (uploads + snapshots + secrets)');
        if (!is_dir(backups_dir($label) . '/files')) { mkdir(backups_dir($label) . '/files', 0775, true); }
        // The app entrypoint chowns the data dirs to www-data = host uid 100032
        // in the rootless userns, so the Orrery user cannot read them directly.
        // `podman unshare` runs tar inside that user namespace (where 100032 maps
        // to the Orrery user), so we capture them faithfully WITHOUT OS root.
        $tarball = backups_dir($label) . "/files/$label-$stamp.tar.zst";
        run_ok([PODMAN, 'unshare', TAR, '--zstd', '-cf', $tarball, '-C', INSTANCES_ROOT, $label],
            'podman unshare tar');
        info("files archived: $tarball");
    }

    // --- stop + remove the pod ---
    if (is_file(quadlet_path($label))) {
        step('stopping ' . service_name($label));
        run([SYSTEMCTL, '--user', 'stop', service_name($label)], user_env()); // ignore if already stopped
        unlink(quadlet_path($label));
        systemd_user(['daemon-reload'], 'daemon-reload');
        info('pod stopped + Quadlet unit removed');
    }
    // Belt-and-braces: remove any lingering pod object.
    run([PODMAN, 'pod', 'rm', '-f', 'telaris-' . $label]);

    // --- nginx route ---
    if (is_file(nginx_vhost_path($label))) {
        step('removing nginx route');
        unlink(nginx_vhost_path($label));
        nginx_reload();
        info('nginx reloaded');
    }

    // --- retract the Pluriverse federation row (if any) ---
    // Through the bridge (db_retract_instance): DELETE (not just set 'withdrawn')
    // so a re-provision of the same label does not hit the UNIQUE(label)
    // constraint; the instance + its keypair are gone anyway. Best-effort: a
    // failure must not block teardown.
    // ponytail: catalog removal only; peer-side trust revocation/notification is
    // a separate stage-6 concern, not done here.
    try {
        $n = (int)pluriverse_call('retract', [$label]);
        if ($n > 0) { info('federation: retracted Pluriverse instances row'); }
    } catch (Throwable $e) {
        warn('federation retract failed (non-fatal): ' . $e->getMessage());
    }

    // --- drop DB + role ---
    db_drop($dbName, $dbUser);

    // --- remove the live tree (NOT the backups) ---
    if (is_dir(instance_dir($label))) {
        step('removing instance tree');
        // Same userns reason as the archive step: the data dirs are owned by
        // uid 100032, so remove them inside `podman unshare` (no OS root).
        run_ok([PODMAN, 'unshare', '/usr/bin/rm', '-rf', instance_dir($label)], 'podman unshare rm -rf');
        info('tree removed (backups kept under ' . backups_dir($label) . ')');
    }

    // --- keyfile + registry ---
    $keyfile = KEYS_DIR . '/telaris-' . $label . '-postgres';
    if (is_file($keyfile)) { unlink($keyfile); info('removed DB keyfile'); }
    unset($reg[$label]);
    registry_save($reg);

    out("Deprovisioned '$label'. Final archives under " . backups_dir($label));
}

// ===========================================================================
// suspend / resume / list / inspect
// ===========================================================================

function cmd_suspend(string $label): void {
    $label = validate_label($label);
    systemd_user(['stop', service_name($label)], 'stop ' . service_name($label));
    $reg = registry_load();
    if (isset($reg[$label])) { $reg[$label]['status'] = 'suspended'; registry_save($reg); }
    out("Suspended '$label' (data retained; resume with: telaris-orrery resume $label).");
}

function cmd_resume(string $label): void {
    $label = validate_label($label);
    systemd_user(['start', service_name($label)], 'start ' . service_name($label));
    $reg = registry_load();
    if (isset($reg[$label])) {
        $reg[$label]['status'] = 'running';
        registry_save($reg);
        info('pod answers (HTTP ' . wait_http((int)$reg[$label]['port'], 60) . ')');
    }
    out("Resumed '$label'.");
}

// ===========================================================================
// worker: drain the Pluriverse provisioning_jobs queue
// ===========================================================================
//
// The Pluriverse web app (www-data) only ever INSERTs a typed job row. This
// worker (the Orrery user) claims jobs FOR UPDATE SKIP LOCKED, re-validates
// every field, and runs the fixed provisioner sequence. No job field is ever
// shell-interpolated: cmd_provision() is called in-process with an option
// array, and all SQL is parameterized. See the trust-boundary section of the
// Self-service instances plan.

/**
 * Call a whitelisted Pluriverse function through the www-data bridge dispatcher.
 * Arguments go as a JSON array on stdin (no shell quoting / no injection); the
 * dispatcher echoes {"ok":bool,...}. Returns the decoded `result` on success.
 * Throws OrreryError on a non-zero exit or an {"ok":false} envelope, so callers
 * that want best-effort behaviour must catch. This is the Orrery's ONLY path to
 * the Pluriverse DB; it holds no DB credentials of its own.
 *
 * @param array<int,mixed> $args
 * @return mixed
 */
function pluriverse_call(string $func, array $args = []) {
    $r = run([
        SUDO, '-n', '-u', 'www-data', '/usr/bin/php', BRIDGE_SCRIPT, $func,
    ], [], json_encode(array_values($args), JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE));
    $out = trim($r['out']);
    $env = json_decode($out, true);
    if (!is_array($env) || !array_key_exists('ok', $env)) {
        throw new OrreryError("bridge '$func' returned no JSON envelope (exit {$r['code']}): "
            . trim($r['err'] ?: $out));
    }
    if ($env['ok'] !== true) {
        throw new OrreryError("bridge '$func' failed: " . (string)($env['error'] ?? 'unknown'));
    }
    return $env['result'] ?? null;
}

/** Load the 32-byte operator-handoff key (shared with the Pluriverse app). */
function handoff_key(): string {
    if (!is_readable(HANDOFF_KEY_FILE)) {
        fail('Operator-handoff key not readable: ' . HANDOFF_KEY_FILE
            . ' (run the host bootstrap to create it, shared theagitist:www-data 0640).');
    }
    $raw = (string)file_get_contents(HANDOFF_KEY_FILE);
    // Accept either 32 raw bytes or 64 hex chars (whitespace-trimmed).
    $t = trim($raw);
    if (strlen($t) === 64 && preg_match('/^[0-9a-f]+$/i', $t)) {
        $raw = (string)hex2bin($t);
    }
    if (strlen($raw) !== SODIUM_CRYPTO_SECRETBOX_KEYBYTES) {
        fail('Operator-handoff key must be ' . SODIUM_CRYPTO_SECRETBOX_KEYBYTES . ' bytes (or 64 hex).');
    }
    return $raw;
}

/** Seal {email,first,last} for a job payload. Format: hex(nonce(24)||cipher). */
function handoff_seal(array $data): string {
    $key = handoff_key();
    $nonce = random_bytes(SODIUM_CRYPTO_SECRETBOX_NONCEBYTES);
    $plain = json_encode($data, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR);
    $cipher = sodium_crypto_secretbox($plain, $nonce, $key);
    sodium_memzero($key);
    return bin2hex($nonce . $cipher);
}

/** Reverse handoff_seal: returns the decoded array, or throws on tamper. */
function handoff_unseal(string $hex): array {
    if ($hex === '' || !preg_match('/^[0-9a-f]+$/i', $hex)) {
        throw new OrreryError('handoff blob is not hex');
    }
    $bytes = (string)hex2bin($hex);
    $nlen = SODIUM_CRYPTO_SECRETBOX_NONCEBYTES;
    if (strlen($bytes) < $nlen + SODIUM_CRYPTO_SECRETBOX_MACBYTES) {
        throw new OrreryError('handoff blob too short');
    }
    $key = handoff_key();
    $plain = sodium_crypto_secretbox_open(substr($bytes, $nlen), substr($bytes, 0, $nlen), $key);
    sodium_memzero($key);
    if ($plain === false) {
        throw new OrreryError('handoff blob auth-tag mismatch (wrong key / tampered)');
    }
    $data = json_decode($plain, true);
    if (!is_array($data)) {
        throw new OrreryError('handoff blob is not a JSON object');
    }
    return $data;
}

/**
 * Atomically claim the next due job (via the bridge: FOR UPDATE SKIP LOCKED so
 * concurrent workers never collide). Returns the claimed row (status already
 * flipped to 'running', attempt_count incremented) or null if the queue is
 * empty.
 */
function worker_claim_job(): ?array {
    $row = pluriverse_call('claim_job');
    return is_array($row) ? $row : null;
}

/** Mark a claimed job done (terminal success). */
function worker_finish_job(int $jobId, array $result): void {
    pluriverse_call('finish_job', [$jobId, $result]);
}

/**
 * Record a failed attempt: re-queue with backoff if attempts remain, else
 * give up. Backoff = attempt^2 minutes (1, 4, 9, 16, ...). Returns
 * 'given_up' or 'requeued'.
 */
function worker_fail_job(int $jobId, int $attemptCount, string $error): string {
    return (string)pluriverse_call('fail_job', [$jobId, $attemptCount, WORKER_MAX_ATTEMPTS, $error]);
}

/** Set instance_requests.status (+ optional instance_id) for a job's request. */
function worker_set_request_status(?int $requestId, string $status, ?int $instanceId = null): void {
    pluriverse_call('set_request_status', [$requestId, $status, $instanceId]);
}

/**
 * 3f auto-trust backfill: read the raw federation public key the freshly
 * provisioned instance minted, and publish its (previously PENDING) Pluriverse
 * `instances` row by writing the key and flipping admission_status to
 * 'published'. The Pluriverse pre-created the row at approval (it holds the PII
 * master key the Orrery lacks) and left public_key empty + status 'pending';
 * reading the key from inside the container is the one piece only the running
 * instance can supply, and the only step that genuinely belongs to the Orrery.
 * The publish itself goes through the bridge (db_publish_instance_key).
 *
 * Returns the published hostname on success, or null if the key could not be
 * read or the row was not in 'pending' (e.g. already published on a retry).
 * Non-fatal: the instance is already serving; auto-trust can be reconciled
 * later.
 */
function worker_publish_instance(int $instanceId, string $label): ?string {
    // Raw 32-byte Ed25519 public key, hex-encoded, from inside the container.
    $r = run([PODMAN, 'exec', app_container($label), 'php', '-r',
        'require_once "/var/www/html/config.php"; '
        . 'require_once "/var/www/html/inc/federation/identity.php"; '
        . 'echo bin2hex(federation_public_key());']);
    $pkHex = trim($r['out']);
    if (!preg_match('/^[0-9a-f]{64}$/', $pkHex)) {
        warn("3f: could not read public key for '$label' (got " . substr($pkHex, 0, 80) . '); leaving instances row pending');
        return null;
    }
    $host = pluriverse_call('publish_key', [$instanceId, $pkHex]); // null if not pending
    if ($host === null) {
        info("3f: instances row #$instanceId for '$label' was not pending (already published?); no change");
        return null;
    }
    info("3f: published instances row #$instanceId ($host) with minted key");
    return (string)$host . ':' . substr($pkHex, 0, 16);
}

/** Run one claimed job to completion. Throws on failure (caller records it). */
function worker_run_job(array $job): array {
    $jobType = (string)$job['job_type'];
    $label = validate_label((string)$job['label']); // re-validate charset / reserved
    $requestId = $job['request_id'] !== null ? (int)$job['request_id'] : null;
    $payload = [];
    if ($job['payload'] !== null && $job['payload'] !== '') {
        $payload = json_decode((string)$job['payload'], true);
        if (!is_array($payload)) { throw new OrreryError('job payload is not a JSON object'); }
    }

    switch ($jobType) {
        case 'provision':
            // Unseal the operator identity (never plaintext at rest in the queue).
            $sealed = (string)($payload['operator_sealed'] ?? '');
            if ($sealed === '') { throw new OrreryError('provision job missing operator_sealed'); }
            $op = handoff_unseal($sealed);
            $email = (string)($op['email'] ?? '');
            if ($email === '' || !filter_var($email, FILTER_VALIDATE_EMAIL)) {
                throw new OrreryError('handoff operator email invalid');
            }
            $federate = array_key_exists('federate', $payload) ? (bool)$payload['federate'] : true;
            $opts = [
                'operator-email' => $email,
                'force' => true, // worker retries must be idempotent
            ];
            if (!empty($op['first']))            { $opts['operator-first'] = (string)$op['first']; }
            if (!empty($op['last']))             { $opts['operator-last']  = (string)$op['last']; }
            if (!empty($payload['site_name']))    { $opts['site-name']      = (string)$payload['site_name']; }
            if (!empty($payload['site_tagline'])) { $opts['site-tagline']   = (string)$payload['site_tagline']; }
            if (!empty($payload['locale']))       { $opts['locale']         = (string)$payload['locale']; }
            if (!empty($payload['quota']))        { $opts['quota']          = (string)$payload['quota']; }
            if (!$federate)                       { $opts['no-federate']    = true; }

            worker_set_request_status($requestId, 'provisioning');
            cmd_provision($label, $opts);

            // Read back the recorded keyid for the job result.
            $reg = registry_load();
            $keyid = $reg[$label]['keyid'] ?? null;

            // 3f auto-trust: if the Pluriverse pre-created a (pending) federation
            // instances row at approval, backfill its minted public key and
            // publish it. instance_id is already linked on the request by the
            // approve step; the publish is non-fatal if it cannot complete.
            $published = null;
            $instanceId = isset($payload['instance_id']) ? (int)$payload['instance_id'] : 0;
            if ($federate && $instanceId > 0) {
                try {
                    $published = worker_publish_instance($instanceId, $label);
                } catch (Throwable $e) {
                    warn('3f publish failed (non-fatal): ' . $e->getMessage());
                }
            }

            worker_set_request_status($requestId, 'provisioned');
            return ['action' => 'provision', 'label' => $label, 'keyid' => $keyid, 'published' => $published];

        case 'deprovision':
            cmd_deprovision($label, ['yes' => true]);
            return ['action' => 'deprovision', 'label' => $label];

        case 'suspend':
            cmd_suspend($label);
            return ['action' => 'suspend', 'label' => $label];

        case 'resume':
            cmd_resume($label);
            return ['action' => 'resume', 'label' => $label];

        default:
            throw new OrreryError("unknown job_type '$jobType'");
    }
}

function cmd_work(array $opts): void {
    $max = isset($opts['max']) ? max(1, (int)$opts['max']) : WORKER_MAX_JOBS;
    $done = 0; $failed = 0; $processed = 0;

    for ($i = 0; $i < $max; $i++) {
        $job = worker_claim_job();
        if ($job === null) break; // queue drained
        $processed++;
        $jobId = (int)$job['id'];
        $requestId = $job['request_id'] !== null ? (int)$job['request_id'] : null;
        step("job#$jobId {$job['job_type']} '{$job['label']}' (attempt {$job['attempt_count']})");
        try {
            $result = worker_run_job($job);
            worker_finish_job($jobId, $result);
            $done++;
            info("job#$jobId done");
        } catch (Throwable $e) {
            $outcome = worker_fail_job($jobId, (int)$job['attempt_count'], $e->getMessage());
            // On terminal give-up of a provision, surface the request as failed.
            if ($outcome === 'given_up' && $job['job_type'] === 'provision') {
                worker_set_request_status($requestId, 'failed');
            }
            $failed++;
            warn("job#$jobId $outcome: " . $e->getMessage());
        }
    }

    if ($processed === 0) {
        out('No due jobs.');
    } else {
        out("Worker pass complete: processed=$processed done=$done failed=$failed.");
    }

    // Disk-usage monitor: cheap, runs every worker tick. Records usage per
    // instance; the instance app self-enforces uploads from TELARIS_QUOTA_BYTES.
    quota_scan();
}

/** Quota in GB (or 'infinite'/0/'') -> bytes; 0 means unlimited. */
function quota_bytes(string $quota): int {
    $q = strtolower(trim($quota));
    if ($q === '' || $q === 'infinite' || $q === '0') { return 0; }
    return (int)round((float)$q * 1073741824); // GiB
}

/**
 * Measure each instance's disk tree and record usage in the registry
 * (disk_used_bytes, over_quota, quota_checked_at). Read-only + best-effort: a
 * single instance's failure never aborts the scan. `du` runs via `podman
 * unshare` because the tree is owned by the container's mapped uid (100032),
 * which the Orrery user cannot stat directly. Enforcement of new uploads lives
 * in the instance app (TELARIS_QUOTA_BYTES); this is the operator-visibility +
 * over-quota-flag half.
 */
function quota_scan(): void {
    $reg = registry_load();
    if (!$reg) { return; }
    $changed = false;
    foreach ($reg as $label => $rec) {
        $dir = instance_dir((string)$label);
        if (!is_dir($dir)) { continue; }
        $r = run([PODMAN, 'unshare', 'du', '-sb', '--', $dir]);
        if ($r['code'] !== 0) {
            warn("quota: du failed for '$label': " . trim($r['err'] ?: $r['out']));
            continue;
        }
        $used = (int)strtok(trim($r['out']), "\t ");
        $limit = quota_bytes((string)($rec['quota'] ?? '0'));
        $over = $limit > 0 && $used > $limit;
        $reg[$label]['disk_used_bytes'] = $used;
        $reg[$label]['over_quota'] = $over;
        $reg[$label]['quota_checked_at'] = gmdate('c');
        $changed = true;
        if ($over) {
            warn(sprintf("quota: '%s' OVER quota (%s used / %s limit)",
                $label, human_bytes($used), human_bytes($limit)));
        }
    }
    if ($changed) { registry_save($reg); }
}

/** Bytes -> short human string (for log lines). */
function human_bytes(int $n): string {
    $u = ['B', 'KiB', 'MiB', 'GiB', 'TiB'];
    $i = 0; $v = (float)$n;
    while ($v >= 1024 && $i < count($u) - 1) { $v /= 1024; $i++; }
    return ($i === 0 ? (string)$n : sprintf('%.1f', $v)) . $u[$i];
}

function cmd_list(): void {
    $reg = registry_load();
    if (!$reg) { out('No instances in the registry.'); return; }
    printf("%-16s %-26s %-7s %-22s %-10s %-5s %s\n", 'LABEL', 'HOSTNAME', 'PORT', 'DB', 'STATUS', 'LIVE', 'DISK');
    foreach ($reg as $r) {
        $live = isset($r['port']) ? curl_status((int)$r['port']) : '-';
        $disk = isset($r['disk_used_bytes'])
            ? human_bytes((int)$r['disk_used_bytes']) . '/' . ($r['quota'] ?? '?') . 'G' . (!empty($r['over_quota']) ? ' OVER' : '')
            : '-';
        printf("%-16s %-26s %-7s %-22s %-10s %-5s %s\n",
            $r['label'] ?? '?', $r['hostname'] ?? '?', (string)($r['port'] ?? '?'),
            $r['db_name'] ?? '?', $r['status'] ?? '?', $live, $disk);
    }
}

function cmd_inspect(string $label): void {
    $label = validate_label($label);
    $reg = registry_load();
    $rec = $reg[$label] ?? null;
    if (!$rec) { fail("No registry record for '$label'."); }
    $rec['live_http'] = isset($rec['port']) ? curl_status((int)$rec['port']) : '-';
    $svc = run([SYSTEMCTL, '--user', 'is-active', service_name($label)], user_env());
    $rec['unit_active'] = trim($svc['out']);
    out(json_encode($rec, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));
}

// ===========================================================================
// arg parsing + dispatch
// ===========================================================================

/** @return array{0:string,1:array<int,string>,2:array<string,string|bool>} */
function parse_args(array $argv): array {
    $cmd = $argv[1] ?? 'help';
    $positional = [];
    $opts = [];
    foreach (array_slice($argv, 2) as $arg) {
        if (preg_match('/^--([a-z][a-z-]*)=(.*)$/s', $arg, $m)) {
            $opts[$m[1]] = $m[2];
        } elseif (preg_match('/^--([a-z][a-z-]*)$/', $arg, $m)) {
            $opts[$m[1]] = true;
        } else {
            $positional[] = $arg;
        }
    }
    return [$cmd, $positional, $opts];
}

function usage(): void {
    out(APP_DESC);
    out('');
    out('Usage:');
    out('  telaris-orrery provision <label> --operator-email=E [--operator-first= --site-name= --locale=en');
    out('                                   --password= --quota=N|infinite --no-federate --force --seed-script=PATH]');
    out('  telaris-orrery deprovision <label> [--yes]');
    out('  telaris-orrery suspend <label>');
    out('  telaris-orrery resume <label>');
    out('  telaris-orrery work [--max=N]      drain the Pluriverse provisioning_jobs queue (also runs a quota scan)');
    out('  telaris-orrery quota               measure disk usage per instance, record over-quota flags');
    out('  telaris-orrery list');
    out('  telaris-orrery inspect <label>');
}

[$cmd, $pos, $opts] = parse_args($argv);

if (posix_getuid() === 0) {
    fail('Do not run telaris-orrery as root; it is a rootless Orrery-user tool (it uses sudo only for `systemctl reload nginx`).');
}

try {
    switch ($cmd) {
        case 'provision':
            if (!isset($pos[0])) { fail('provision needs a <label>.'); }
            cmd_provision($pos[0], $opts);
            break;
        case 'deprovision':
            if (!isset($pos[0])) { fail('deprovision needs a <label>.'); }
            cmd_deprovision($pos[0], $opts);
            break;
        case 'suspend':
            if (!isset($pos[0])) { fail('suspend needs a <label>.'); }
            cmd_suspend($pos[0]);
            break;
        case 'resume':
            if (!isset($pos[0])) { fail('resume needs a <label>.'); }
            cmd_resume($pos[0]);
            break;
        case 'work':    cmd_work($opts); break;
        case 'quota':   quota_scan(); out('Quota scan complete.'); break;
        case 'list':    cmd_list(); break;
        case 'inspect':
            if (!isset($pos[0])) { fail('inspect needs a <label>.'); }
            cmd_inspect($pos[0]);
            break;
        case 'help':
        case '--help':
        case '-h':
            usage();
            break;
        default:
            warn("Unknown command: $cmd");
            usage();
            exit(2);
    }
} catch (Throwable $e) {
    fwrite(STDERR, "[x] " . $e->getMessage() . "\n");
    exit(1);
}
